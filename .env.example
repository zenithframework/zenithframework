# Application
APP_NAME="Zenith Framework"
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost
APP_KEY=

# Database
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=database/database.sqlite
DB_USERNAME=root
DB_PASSWORD=
DB_PREFIX=

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=zenith_

# Session
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@example.com
MAIL_FROM_NAME="${APP_NAME}"

# Queue
QUEUE_CONNECTION=sync

# AI
AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4

# Security
SECURITY_ENABLE_WAF=true
SECURITY_ENABLE_RATE_LIMIT=true
SECURITY_RATE_LIMIT=60
SECURITY_MAX_LOGIN_ATTEMPTS=5

# Logging
LOG_CHANNEL=single
LOG_LEVEL=debug
