        'Make Commands' => array_filter($commands, fn($k) => str_starts_with($k, 'make:'), ARRAY_FILTER_USE_KEY),
        'Remove Commands' => array_filter($commands, fn($k) => str_starts_with($k, 'remove:'), ARRAY_FILTER_USE_KEY),
        'Rename Commands' => array_filter($commands, fn($k) => str_starts_with($k, 'rename:'), ARRAY_FILTER_USE_KEY),
        'Database Commands' => array_intersect_key($commands, array_flip(['migrate', 'migrate:rollback', 'migrate:refresh', 'migrate:fresh', 'migrate:reset', 'db:seed', 'db:wipe', 'db:status', 'db:tables', 'db:dump', 'db:import', 'migration:status'])),
        'Model Commands' => array_intersect_key($commands, array_flip(['model:list', 'model:show'])),
        'Controller Commands' => array_intersect_key($commands, array_flip(['controller:list'])),
        'Middleware Commands' => array_intersect_key($commands, array_flip(['middleware:list'])),
        'View Commands' => array_intersect_key($commands, array_flip(['view:list', 'view:cache'])),
        'Route Commands' => array_intersect_key($commands, array_flip(['route:list', 'route:cache', 'route:test', 'route:fix', 'route:convert', 'route:group', 'api:test'])),
        'Cache Commands' => array_intersect_key($commands, array_flip(['cache:clear', 'cache:ssr', 'cache:stats', 'cache:forget'])),
        'Queue Commands' => array_intersect_key($commands, array_flip(['queue:failed', 'queue:retry', 'queue:flush', 'queue:work', 'queue:listen', 'queue:table'])),
        'Session Commands' => array_intersect_key($commands, array_flip(['session:clear', 'session:stats'])),
        'Storage Commands' => array_intersect_key($commands, array_flip(['storage:link', 'storage:stats'])),
        'Log Commands' => array_intersect_key($commands, array_flip(['log:clear', 'log:show'])),
        'Debug Commands' => array_intersect_key($commands, array_flip(['debug:info', 'debug:log', 'debug:clear'])),
        'Env Commands' => array_intersect_key($commands, array_flip(['env:set', 'env:get'])),
        'Config Commands' => array_intersect_key($commands, array_flip(['config:show', 'config:set'])),
        'Seeder Commands' => array_intersect_key($commands, array_flip(['seeder:list'])),
        'Factory Commands' => array_intersect_key($commands, array_flip(['factory:list'])),
        'Validation Commands' => array_intersect_key($commands, array_flip(['validation:test'])),
        'Scheduler Commands' => array_intersect_key($commands, array_flip(['scheduler:run', 'scheduler:list'])),
        'Event Commands' => array_intersect_key($commands, array_flip(['event:list', 'event:test'])),
        'Auth Commands' => array_intersect_key($commands, array_flip(['gate:list', 'policy:list'])),
        'Mail Commands' => array_intersect_key($commands, array_flip(['mail:test'])),
        'App Commands' => array_intersect_key($commands, array_flip(['app:key', 'app:down', 'app:up'])),
        'Analyzer Commands' => array_intersect_key($commands, array_flip(['analyzer:bugs', 'analyzer:security'])),
        'SSR Commands' => array_intersect_key($commands, array_flip(['ssr'])),
        'Other Commands' => array_intersect_key($commands, array_flip(['serve', 'class:resolve', 'lint', 'test', 'new', 'optimize:clear'])),
    ];

    foreach ($categories as $category => $cmds) {
        if (empty($cmds)) {
            continue;
        }

        echo "\n{$category}:\n";
        foreach (array_keys($cmds) as $name) {
            // Try to get description from command class
            $commandClass = $cmds[$name];
            $description = '';

            if (class_exists($commandClass)) {
                $instance = new $commandClass();
                $reflection = new ReflectionClass($instance);
                if ($reflection->hasProperty('description')) {
                    $prop = $reflection->getProperty('description');
                    $description = '  ' . $prop->getValue($instance);
                }
            }

            printf("  %-30s%s\n", $name, $description);
        }
    }

    echo "\nUse \"php zen <command> --help\" for more information about a specific command.\n";
    exit(0);
}

$commandName = $argv[0];
$arguments = array_slice($argv, 1);

if (!isset($commands[$commandName])) {
    echo "Command '{$commandName}' not found.\n";
    exit(1);
}

$commandClass = $commands[$commandName];

if (!class_exists($commandClass)) {
    echo "Command class '{$commandClass}' not found.\n";
    exit(1);
}

$command = new $commandClass();
$command->handle($app, $arguments);
